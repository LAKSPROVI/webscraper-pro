# =============================================================================
# .env.example — Variáveis de Ambiente do WebScraper Jurídico
# =============================================================================
# IMPORTANTE: Copie este arquivo para .env e substitua os valores padrão
#   cp .env.example .env
#
# NUNCA faça commit do arquivo .env com senhas reais!
# O arquivo .env.example deve ser versionado (sem dados sensíveis)
# =============================================================================

# -----------------------------------------------------------------------------
# BANCO DE DADOS — PostgreSQL
# -----------------------------------------------------------------------------
# Nome do banco de dados principal
POSTGRES_DB=webscraper

# Usuário do PostgreSQL
POSTGRES_USER=scraper

# Senha do PostgreSQL — ALTERE ANTES DE USAR EM PRODUÇÃO
POSTGRES_PASSWORD=scraper_pass_change_me

# Host do PostgreSQL (nome do serviço Docker)
POSTGRES_HOST=postgres

# Porta do PostgreSQL
POSTGRES_PORT=5432

# URL completa de conexão (usada pelo SQLAlchemy/asyncpg)
DATABASE_URL=postgresql+asyncpg://scraper:scraper_pass_change_me@postgres:5432/webscraper

# URL de conexão síncrona (usada para migrações Alembic)
DATABASE_SYNC_URL=postgresql://scraper:scraper_pass_change_me@postgres:5432/webscraper

# -----------------------------------------------------------------------------
# CACHE / BROKER — Redis
# -----------------------------------------------------------------------------
# URL do Redis para uso geral (cache, sessões)
REDIS_URL=redis://redis:6379/0

# URL do broker do Celery (database 0)
CELERY_BROKER_URL=redis://redis:6379/0

# URL do backend de resultados do Celery (database 1)
CELERY_RESULT_BACKEND=redis://redis:6379/1

# TTL padrão de cache em segundos (1 hora)
REDIS_TTL=3600

# -----------------------------------------------------------------------------
# API — FastAPI
# -----------------------------------------------------------------------------
# Host de bind da API
API_HOST=0.0.0.0

# Porta da API
API_PORT=8000

# Chave secreta para assinatura de tokens JWT — GERE UMA ALEATÓRIA
# Exemplo: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=change_me_to_random_secret_at_least_32_chars

# Algoritmo JWT
API_JWT_ALGORITHM=HS256

# Validade do token JWT em minutos (8 horas)
API_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Origens permitidas para CORS (separadas por vírgula)
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Modo de execução: development | production
API_ENV=development

# Debug mode (true em dev, false em produção)
API_DEBUG=false

# Versão da API
API_VERSION=v1

# -----------------------------------------------------------------------------
# CELERY — Worker e Beat
# -----------------------------------------------------------------------------
# Porta do Flower (monitor do Celery)
FLOWER_PORT=5555

# Nível de log dos workers (debug | info | warning | error)
CELERY_LOG_LEVEL=info

# Concorrência (número de processos por worker)
CELERY_WORKER_CONCURRENCY=4

# Máximo de tarefas por processo (evita memory leak)
CELERY_WORKER_MAX_TASKS_PER_CHILD=100

# Timeout de tarefas em segundos (30 minutos)
CELERY_TASK_SOFT_TIME_LIMIT=1800
CELERY_TASK_TIME_LIMIT=2100

# Retry delay em segundos
CELERY_RETRY_DELAY=60

# Número máximo de retries por tarefa
CELERY_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# GRAFANA
# -----------------------------------------------------------------------------
# Senha do admin do Grafana — ALTERE ANTES DE USAR
GRAFANA_ADMIN_PASSWORD=admin_change_me

# Usuário admin do Grafana
GRAFANA_ADMIN_USER=admin

# URL base do Grafana (para links em alertas)
GRAFANA_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# PGADMIN — Interface web PostgreSQL
# -----------------------------------------------------------------------------
# Email de login do pgAdmin
PGADMIN_EMAIL=admin@webscraper.local

# Senha do pgAdmin — ALTERE ANTES DE USAR
PGADMIN_PASSWORD=pgadmin_change_me

# -----------------------------------------------------------------------------
# SCRAPER — Configurações de comportamento
# -----------------------------------------------------------------------------
# Número máximo de requisições simultâneas
MAX_CONCURRENT_REQUESTS=16

# Delay mínimo entre requisições (segundos) — evita bloqueio
DEFAULT_DELAY_MIN=1.0

# Delay máximo entre requisições (segundos)
DEFAULT_DELAY_MAX=3.0

# Timeout de conexão HTTP em segundos
REQUEST_TIMEOUT=30

# Timeout total de uma tarefa de scraping em segundos
SCRAPING_TIMEOUT=120

# User-Agent padrão para requisições
DEFAULT_USER_AGENT=Mozilla/5.0 (compatible; WebScraper/1.0; +http://localhost)

# Número máximo de redirects a seguir
MAX_REDIRECTS=5

# -----------------------------------------------------------------------------
# PROXY — Configurações de proxy (opcional)
# -----------------------------------------------------------------------------
# Habilita uso de proxies (true | false)
PROXY_ENABLED=false

# URL do proxy HTTP (se habilitado)
# Exemplo: http://usuario:senha@proxy.exemplo.com:8080
PROXY_HTTP_URL=

# URL do proxy HTTPS (se habilitado)
PROXY_HTTPS_URL=

# Lista de hosts que ignoram proxy (separados por vírgula)
PROXY_NO_PROXY=localhost,127.0.0.1,postgres,redis

# Rotação automática de proxy (true | false)
PROXY_ROTATION_ENABLED=false

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Nível de log global (DEBUG | INFO | WARNING | ERROR | CRITICAL)
LOG_LEVEL=INFO

# Formato de log: json | text
LOG_FORMAT=json

# Tamanho máximo do arquivo de log em bytes (10MB)
LOG_MAX_BYTES=10485760

# Número de arquivos de backup de log
LOG_BACKUP_COUNT=5

# -----------------------------------------------------------------------------
# PLAYWRIGHT — Browser automatizado
# -----------------------------------------------------------------------------
# Browser a usar: chromium | firefox | webkit
PLAYWRIGHT_BROWSER=chromium

# Executar em modo headless (true = sem interface gráfica)
PLAYWRIGHT_HEADLESS=true

# Timeout do Playwright em milissegundos (30 segundos)
PLAYWRIGHT_TIMEOUT=30000

# Resolução do viewport do browser
PLAYWRIGHT_VIEWPORT_WIDTH=1280
PLAYWRIGHT_VIEWPORT_HEIGHT=720

# Ignorar erros de certificado SSL
PLAYWRIGHT_IGNORE_HTTPS_ERRORS=false

# -----------------------------------------------------------------------------
# ALERTAS E NOTIFICAÇÕES (opcional)
# -----------------------------------------------------------------------------
# Webhook do Slack para alertas (opcional)
SLACK_WEBHOOK_URL=

# Email para envio de alertas (opcional)
ALERT_EMAIL=

# SMTP para envio de email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
