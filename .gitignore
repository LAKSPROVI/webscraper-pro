# =============================================================================
# .gitignore — WebScraper Jurídico
# =============================================================================

# Variáveis de ambiente com dados sensíveis (NUNCA versionar)
.env
.env.local
.env.production
.env.staging

# Credenciais locais (NUNCA versionar)
CREDENTIALS*
*.credentials
*.secret

# Dados gerados pelos containers (não versionar)
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# Caches Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Ambientes virtuais
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store
Thumbs.db

# Playwright
playwright-report/
test-results/

# Docker volumes (se montados localmente)
data/

# Uploads e outputs temporários
uploads/
temp/
downloads/

# Frontend artefatos locais
frontend/node_modules/
frontend/dist/
frontend/storybook-static/

# Artefatos locais de export/sessao do Copilot
copilot_chat_export.json
copilot_chat_export.md
STRATEGY_COPILOT_EXPORT.md
docs/copilot-sessions/
scripts/export_copilot_chat.py

# Sessao autenticada local para scraping
*.storage-state.json
*.cookies.json
sessions/
